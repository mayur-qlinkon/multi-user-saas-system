    <script>
        // Global lucide reinit — call this after any dynamic DOM injection
        window.initIcons = function(scope) {
            if (typeof lucide === 'undefined') return;
            lucide.createIcons({
                // If scope passed, only scan that element — more performant
                nodes: scope ? scope.querySelectorAll('[data-lucide]') : undefined
            });
        };
        document.addEventListener("DOMContentLoaded", () => {
            window.initIcons();
        });

        /* ═══════════════════════════════════════════════════════
           PAGE TRANSITION
           Kills FOUC and adds smooth enter/exit between pages
        ═══════════════════════════════════════════════════════ */
        (function() {
            const cover = document.getElementById('page-cover');

            document.addEventListener('DOMContentLoaded', () => {
                document.body.style.transition = 'opacity 180ms ease';
                document.body.style.opacity = '1';
                requestAnimationFrame(() => {
                    cover.style.opacity = '0';
                    setTimeout(() => cover.remove(), 240);
                });
            });



        })();

        /* ═══════════════════════════════════════════════════════
           ACCORDION — pure JS, single-open (one at a time)
        ═══════════════════════════════════════════════════════ */
        (function() {
            const groups = Array.from(document.querySelectorAll('.acc-group'));

            function open(group, instant) {
                const wrap = group.querySelector('.acc-wrap');
                const chevron = group.querySelector('.nav-chevron');
                const trigger = group.querySelector('.acc-trigger');

                if (instant) {
                    // No animation on page load — prevents layout flash
                    wrap.style.transition = 'none';
                    wrap.style.maxHeight = wrap.scrollHeight + 'px';
                    wrap.style.opacity = '1';
                    requestAnimationFrame(() => requestAnimationFrame(() => {
                        wrap.style.transition = ''; // restore after paint
                    }));
                } else {
                    wrap.style.maxHeight = wrap.scrollHeight + 'px';
                    wrap.style.opacity = '1';
                }

                chevron && chevron.classList.add('rotated');
                trigger && trigger.classList.add('acc-open');
                group._open = true;
            }

            function close(group) {
                const wrap = group.querySelector('.acc-wrap');
                const chevron = group.querySelector('.nav-chevron');
                const trigger = group.querySelector('.acc-trigger');

                wrap.style.maxHeight = '0';
                wrap.style.opacity = '0';
                chevron && chevron.classList.remove('rotated');
                trigger && trigger.classList.remove('acc-open');
                group._open = false;
            }

            // Boot: open active group instantly, close others
            groups.forEach(group => {
                const shouldOpen = group.dataset.open === 'true';
                group._open = shouldOpen;
                shouldOpen ? open(group, true) : close(group);

                group.querySelector('.acc-trigger')?.addEventListener('click', () => {
                    const isCurrentlyOpen = group._open;

                    // Close ALL others with animation
                    groups.forEach(g => {
                        if (g !== group && g._open) close(g);
                    });

                    // Toggle clicked group
                    isCurrentlyOpen ? close(group) : open(group, false);
                });
            });
        })();

        /* ═══════════════════════════════════════════════════════
           SIDEBAR (mobile)
        ═══════════════════════════════════════════════════════ */
        function toggleSidebar() {
            document.getElementById('main-sidebar').classList.contains('sidebar-open') ?
                closeSidebar() : openSidebar();
        }

        function openSidebar() {
            document.getElementById('main-sidebar').classList.add('sidebar-open');
            document.getElementById('sidebar-overlay').classList.add('active');
            document.getElementById('hamburger-btn').classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            document.getElementById('main-sidebar').classList.remove('sidebar-open');
            document.getElementById('sidebar-overlay').classList.remove('active');
            document.getElementById('hamburger-btn')?.classList.remove('is-open');
            document.body.style.overflow = '';
        }
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 1024) closeSidebar();
        });
    </script>

    <script src="{{ asset('assets/js/swal.js') }}"></script>
